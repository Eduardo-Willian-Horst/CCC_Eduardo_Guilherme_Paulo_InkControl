DJANGO_SECRET_KEY=troque-em-producao
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (opcional): descomente e suba o Docker na raiz (`docker compose up -d`).
# Com POSTGRES_DB definido, o Django usa Postgres; sem isso, usa SQLite em backend/db.sqlite3.
# POSTGRES_DB=inkcontrol
# POSTGRES_USER=inkcontrol
# POSTGRES_PASSWORD=inkcontrol
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# E-mail (SMTP). Sem EMAIL_HOST usa console (desenvolvimento).
# Em producao use SMTP real:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_FAIL_SILENTLY=false
# EMAIL_HOST=smtp.exemplo.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=InkControl <noreply@seudominio.com>
# FRONTEND_PASSWORD_RESET_URL=http://localhost:5173/redefinir-senha

# Tarefas automáticas de lembretes e purge (HU18/HU10) — rodam junto do runserver em desenvolvimento.
# Para desligar temporariamente:
# ENABLE_EMAIL_SCHEDULER=false
# SCHEDULER_INTERVAL_MINUTES=5

# Sessao (RNF05) e bloqueio de login (RNF06)
# TOKEN_INACTIVITY_MINUTES=30
# LOGIN_MAX_FAILED_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15

# Assinatura (middleware). Desative em testes locais se precisar: false
# SUBSCRIPTION_GATE_ENABLED=true
# SUBSCRIPTION_BILLING_PERIOD_DAYS=30

# Cloudflare R2 (S3 API) — opcional para imagens em producao
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# AWS_S3_REGION_NAME=auto
# AWS_DEFAULT_ACL=private
# AWS_QUERYSTRING_AUTH=true

# RNF01 — orcamento de tempo de resposta (testes em tests_ops)
# API_RESPONSE_TIME_BUDGET_MS=2000
